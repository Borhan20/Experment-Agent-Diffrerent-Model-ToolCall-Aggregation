# ─────────────────────────────────────────────────────────────────────────────
# Multi-Agent Orchestration System — Environment Variables
# Copy this file to .env and fill in your API keys.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Required if any llm_role in settings.yaml uses provider: "anthropic"
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Required if any llm_role in settings.yaml uses provider: "openai"
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Required if any llm_role in settings.yaml uses provider: "gemini"
# Get yours at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIza...
